# Mealie API configuration
MEALIE_BASE_URL=http://mealie:9000
MEALIE_API_KEY=replace-with-your-mealie-api-key

# Wrapper HTTP configuration
MCP_HOST=0.0.0.0
MCP_PORT=8000
MCP_PATH=/mcp

# Optional second-level network allowlist. Empty means allow all direct peers.
# Behind a reverse proxy, this usually needs to include the proxy/container subnet.
MCP_ALLOWED_SUBNETS=

# Logging
LOG_LEVEL=INFO
